# Copy this file to `.env` and fill in your own keys (the real .env is gitignored).
# TabPFN hosted inference — get a token from https://www.priorlabs.ai (required).
TABPFN_API_KEY=your_tabpfn_token_here
# the-odds-api.com key for live market-odds blending (optional; free tier = 500 req/mo).
# Omit it and predict.py falls back to model-only predictions.
ODDS_API_KEY=your_odds_api_key_here
